# A2Z Core — example environment. Copy to `.env` for local dev.
# No real secrets here. In AWS, credentials come from the ECS task IAM role.

# --- Runtime ---
A2Z_ENV=local                      # local | dev | prod
A2Z_LOG_LEVEL=INFO                 # DEBUG only when actively debugging (logs cost money)
AWS_REGION=us-east-1

# --- LocalStack override ---
# When set, all boto3 clients point here instead of real AWS. Unset in prod.
AWS_ENDPOINT_URL=http://localhost:4566
# Dummy creds so boto3 is happy against LocalStack; ignored in prod (IAM role used).
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Postgres (shared instance, service-owned schemas — Omni-Channel first) ---
DATABASE_URL=postgresql+asyncpg://a2z:a2z-local-dev-only@localhost:5432/a2z

# --- DynamoDB table names (overridable per environment) ---
DDB_MEMBERSHIP_TABLE=a2z-core-membership
DDB_AUDIT_TABLE=a2z-core-audit
DDB_SETTINGS_TABLE=a2z-core-settings
DDB_EMAIL_EVENTS_TABLE=a2z-core-email-events
DDB_SUPPRESSION_TABLE=a2z-core-suppression
DDB_FILES_TABLE=a2z-core-files

# --- S3 ---
S3_BUCKET=a2z-ledger

# --- EventBridge ---
EVENT_BUS_NAME=a2z-bus

# --- SES ---
# SNS topic attached to each lazily-created config set for Bounce/Complaint
# notifications (CLAUDE.md §8). Leave empty to skip (bounce tracking off).
SES_NOTIFICATIONS_TOPIC_ARN=

# --- Cognito (real values supplied in dev/prod; tests use the test-token factory) ---
COGNITO_USER_POOL_ID=
COGNITO_REGION=us-east-1
COGNITO_APP_CLIENT_ID=

# --- Test-token signing (HS256). ONLY used when A2Z_ENV != prod. ---
TEST_JWT_SECRET=local-development-only-not-a-real-secret
